{
  "name": "captura-unificada",
  "productName": "Captura Unificada",
  "version": "1.0.38",
  "description": "Launcher de sistemas integrados",
  "main": "main.js",
  "author": "Jeferson Oliveira",
  "copyright": "©Jeferson Oliveira - 2026",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "node --no-deprecation node_modules/electron-builder/out/cli/cli.js --win --x64",
    "postinstall": "node scripts/copy-fontawesome.js"
  },
  "engines": {
    "electron": "40.0.0",
    "node": ">=24.11.0"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.4.2",
    "electron": "40.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.consorcio.capturaunificada",
    "productName": "Captura Unificada",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "iJeferson",
        "repo": "captura-unificada"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "src/**/*",
      "ui/**/*",
      "!**/*.md",
      "!**/*.map"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png",
      "executableName": "Captura Unificada",
      "artifactName": "Captura-Unificada-Setup.exe",
      "compression": "maximum"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Captura Unificada",
      "runAfterFinish": true,
      "uninstallDisplayName": "Captura Unificada",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true,
      "include": "build/installer.nsh"
    }
  }
}
